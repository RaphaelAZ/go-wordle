meta {
  name: Save Config
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/config
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "config": {
      "theme": "dark",
      "language": "fr"
    },
    "state": {
      "last_word_id": 1,
      "streak": 3
    }
  }
}
