meta {
  name: Create Game
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/games
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "word_id": 1,
    "attempts": ["CRANE", "CLOWN", "BLANC"],
